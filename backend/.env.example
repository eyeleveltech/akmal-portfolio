# PostgreSQL connection string used by Prisma and the pg pool.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/akmal_portfolio?schema=public"

# Port the API listens on (defaults to 5000).
PORT=5000

# Admin credentials for /api/admin/login. CHANGE THESE — the code falls back
# to insecure defaults (admin / password123) if left unset.
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me"

# Secret used to sign admin JWTs. Use a long random string in production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-secret"

# Google OAuth credentials for creating Google Meet links on bookings.
# Optional: if unset, bookings are still saved but without a Meet link.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REFRESH_TOKEN=""

# Timezone the booked times are interpreted in (IANA name). Defaults to Asia/Kolkata.
GOOGLE_CALENDAR_TIMEZONE="Asia/Kolkata"
